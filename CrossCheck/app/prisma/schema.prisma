generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  teacher
  researcher
}

enum ActivityType {
  presentation
  discussion
}

enum SessionStatus {
  active
  complete
}

enum GroupPhase {
  individual
  group
  reviewing
}

enum SessionStage {
  recognize
  explain
  locate
  results
}

enum FlawType {
  reasoning
  epistemic
  completeness
  coherence
}

enum Severity {
  minor
  moderate
  major
}

// --- Users ---

model User {
  id             String   @id @default(uuid()) @db.Uuid
  username       String   @unique
  passwordHash   String?  @map("password_hash")
  displayName    String   @map("display_name")
  role           Role
  researchConsent Boolean @default(false) @map("research_consent")
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  creator        User?    @relation("CreatedUsers", fields: [createdBy], references: [id])
  createdUsers   User[]   @relation("CreatedUsers")

  teacherClasses Class[]        @relation("TeacherClasses")
  classStudents  ClassStudent[]
  sessions       Session[]
  groupMembers   GroupMember[]
  groupReady     GroupReady[]
  annotations    Annotation[]
  flawResponses  FlawResponse[]
  scaffolds      Scaffold[]
  sessionEvents  SessionEvent[]
  annotationComments AnnotationComment[]
  hintUsages     HintUsage[]    @relation("HintUsageStudent")
  explanations   Explanation[]  @relation("ExplanationAuthor")

  @@map("users")
}

// --- Classes ---

model Class {
  id        String   @id @default(uuid()) @db.Uuid
  teacherId String   @map("teacher_id") @db.Uuid
  name      String   // e.g., "6th STEM Period 2"
  createdAt DateTime @default(now()) @map("created_at")

  teacher   User     @relation("TeacherClasses", fields: [teacherId], references: [id])
  students  ClassStudent[]
  sessions  Session[]

  @@map("classes")
}

model ClassStudent {
  classId String @map("class_id") @db.Uuid
  userId  String @map("user_id") @db.Uuid

  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id])

  @@id([classId, userId])
  @@map("class_students")
}

// --- Activities (imported from registry YAML) ---

model Activity {
  id                String       @id @default(uuid()) @db.Uuid
  scenarioId        String       @unique @map("scenario_id")
  type              ActivityType
  topic             String
  agents            Json         // [{agent_id, name, role}]
  transcript        Json         // Full transcript with metadata
  transcriptContent Json         @map("transcript_content") // Content only, metadata stripped
  evaluation        Json         // Full evaluation
  flawIndex         Json         @map("flaw_index") // [{flaw_id, locations, flaw_type, severity}]
  metadata          Json?        // Scenario design + agent profiles (researcher only)
  createdAt         DateTime     @default(now()) @map("created_at")

  sessions          Session[]

  @@map("activities")
}

// --- Sessions ---

model Session {
  id         String        @id @default(uuid()) @db.Uuid
  teacherId  String        @map("teacher_id") @db.Uuid
  classId    String?       @map("class_id") @db.Uuid
  activityId String        @map("activity_id") @db.Uuid
  status     SessionStatus @default(active)
  config     Json          @default("{}") // {difficulty_mode, phase_timer, etc.}
  notes      String?       // Teacher notes about this session
  createdAt  DateTime      @default(now()) @map("created_at")
  completedAt DateTime?    @map("completed_at")

  teacher    User          @relation(fields: [teacherId], references: [id])
  class      Class?        @relation(fields: [classId], references: [id])
  activity   Activity      @relation(fields: [activityId], references: [id])
  groups     Group[]
  scaffolds  Scaffold[]
  events     SessionEvent[]
  hintUsages HintUsage[]
  explanations Explanation[]

  @@map("sessions")
}

// --- Groups ---

model Group {
  id        String       @id @default(uuid()) @db.Uuid
  sessionId String       @map("session_id") @db.Uuid
  name      String
  phase     GroupPhase   @default(individual)
  stage     SessionStage @default(recognize)
  config    Json         @default("{}") // Legacy: was {difficulty_mode, ...knobs}. Now unused — stage field controls flow.

  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  members   GroupMember[]
  readySignals GroupReady[]
  annotations Annotation[]
  flawResponses FlawResponse[]
  scaffolds Scaffold[]
  hintUsages HintUsage[]
  explanations Explanation[]

  @@map("groups")
}

model GroupReady {
  groupId String @map("group_id") @db.Uuid
  userId  String @map("user_id") @db.Uuid

  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id])

  @@id([groupId, userId])
  @@map("group_ready")
}

model GroupMember {
  groupId String @map("group_id") @db.Uuid
  userId  String @map("user_id") @db.Uuid

  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id])

  @@id([groupId, userId])
  @@map("group_members")
}

// --- Annotations ---

model Annotation {
  id            String    @id @default(uuid()) @db.Uuid
  groupId       String    @map("group_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  location      Json      // {section_id or turn_id, start_offset, end_offset, highlighted_text}
  flawType      FlawType  @map("flaw_type")
  severity      Severity?
  explanation   String?
  hinted        Boolean   @default(false)
  hintLevel     Int       @default(0) @map("hint_level") // Locate: how many hints used before flagging (0 = independent)
  targetSection String?   @map("target_section") // Locate: which section student tapped for hints
  isGroupAnswer Boolean   @default(false) @map("is_group_answer")
  confirmedBy   Json?     @map("confirmed_by") // [user_ids]
  createdAt     DateTime  @default(now()) @map("created_at")

  group         Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id])
  comments      AnnotationComment[]

  @@index([groupId, createdAt])
  @@index([groupId, isGroupAnswer])
  @@map("annotations")
}

// --- Annotation Comments (teacher feedback on specific annotations) ---

model AnnotationComment {
  id           String     @id @default(uuid()) @db.Uuid
  annotationId String     @map("annotation_id") @db.Uuid
  teacherId    String     @map("teacher_id") @db.Uuid
  text         String
  isBonus      Boolean    @default(false) @map("is_bonus") // Teacher flags annotation as bonus find
  createdAt    DateTime   @default(now()) @map("created_at")

  annotation   Annotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  teacher      User       @relation(fields: [teacherId], references: [id])

  @@map("annotation_comments")
}

// --- Flaw Responses (Recognize mode structured answers) ---

model FlawResponse {
  id            String   @id @default(uuid()) @db.Uuid
  groupId       String   @map("group_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  flawId        String   @map("flaw_id")
  typeAnswer    String   @map("type_answer")
  typeCorrect   Boolean  @map("type_correct")
  reasonAnswer  String?  @map("reason_answer")
  reasonCorrect Boolean? @map("reason_correct")
  hintLevel     Int      @default(0) @map("hint_level") // Recognize: how many hints used before answering
  stage         String?  // "recognize" or "explain" — null for legacy/learn responses
  createdAt     DateTime @default(now()) @map("created_at")

  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id])

  @@index([groupId, flawId])
  @@map("flaw_responses")
}

// --- Scaffolds ---

model Scaffold {
  id             String    @id @default(uuid()) @db.Uuid
  sessionId      String    @map("session_id") @db.Uuid
  groupId        String    @map("group_id") @db.Uuid
  teacherId      String    @map("teacher_id") @db.Uuid
  level          Int       // 1-6
  type           String    // attention_redirect, comparison_prompt, etc.
  text           String
  targetLocation Json?     @map("target_location") // {references: [section_ids/turn_ids]}
  contextAtSend  Json      @map("context_at_send") // {annotations_count, sections_touched, time_in_session_minutes}
  outcome        Json?     // Null in v1. Populated by post-session analysis in v2.
  createdAt      DateTime  @default(now()) @map("created_at")
  deliveredAt    DateTime? @map("delivered_at")
  acknowledgedAt DateTime? @map("acknowledged_at")

  session        Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  group          Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teacher        User      @relation(fields: [teacherId], references: [id])

  @@index([sessionId, groupId])
  @@map("scaffolds")
}

// --- Session Events ---

model SessionEvent {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  eventType String   @map("event_type") // phase_changed, scaffold_sent, annotation_created, etc.
  actorId   String?  @map("actor_id") @db.Uuid
  payload   Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  actor     User?    @relation(fields: [actorId], references: [id])

  @@index([sessionId, createdAt])
  @@map("session_events")
}

// --- Hint Usage (tracks hint requests per student per turn/flaw) ---

model HintUsage {
  id            String   @id @default(uuid()) @db.Uuid
  studentId     String   @map("student_id") @db.Uuid
  sessionId     String   @map("session_id") @db.Uuid
  groupId       String   @map("group_id") @db.Uuid
  flawId        String?  @map("flaw_id") // null for non-flawed turns in Recognize
  turnId        String   @map("turn_id") // which turn (item_id) the hint relates to
  hintLevel     Int      @map("hint_level") // 1, 2, or 3
  stage         String   // "recognize", "explain", "locate"
  targetSection String?  @map("target_section") // Locate only: which section student tapped
  createdAt     DateTime @default(now()) @map("created_at")

  student       User     @relation("HintUsageStudent", fields: [studentId], references: [id])
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([studentId, sessionId])
  @@index([groupId])
  @@map("hint_usages")
}

// --- Explanations (collaborative writing in Explain stage) ---

model Explanation {
  id         String   @id @default(uuid()) @db.Uuid
  turnId     String   @map("turn_id") // which turn this explains
  authorId   String   @map("author_id") @db.Uuid
  groupId    String   @map("group_id") @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  text       String
  revisionOf String?  @map("revision_of") @db.Uuid // id of the Explanation this revises (null = original)
  createdAt  DateTime @default(now()) @map("created_at")

  author     User     @relation("ExplanationAuthor", fields: [authorId], references: [id])
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([groupId, turnId])
  @@index([authorId])
  @@map("explanations")
}
